<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle shadow/glow (Green-tinted) -->
    <item>
        <shape>
            <solid android:color="#0A2D6A4F" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Card Foreground -->
    <item
        android:bottom="2dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#FFFFFF"
                android:endColor="#F0F7F4"
                android:type="linear" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/pastel_card_stroke" />
        </shape>
    </item>
</layer-list>
