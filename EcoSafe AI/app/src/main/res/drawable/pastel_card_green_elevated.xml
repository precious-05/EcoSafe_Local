<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft shadow (Green-tinted) -->
    <item>
        <shape>
            <solid android:color="#062D6A4F" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Middle soft shadow -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape>
            <solid android:color="#0A2D6A4F" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Inner shadow/glow -->
    <item
        android:bottom="2.5dp"
        android:left="2.5dp"
        android:right="2.5dp"
        android:top="2.5dp">
        <shape>
            <solid android:color="#142D6A4F" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Card Foreground -->
    <item
        android:bottom="4dp"
        android:left="3dp"
        android:right="3dp"
        android:top="2dp">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#FFFFFF"
                android:endColor="#EEF7F0"
                android:type="linear" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/pastel_card_stroke" />
        </shape>
    </item>
</layer-list>
