<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HistoryActivity">

    <!-- Custom Parallax Starfield Background -->
    <com.example.eco_front.AnimatedBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Main Content Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar with Header Spacing -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:paddingTop="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp">

                <ImageView
                    android:id="@+id/iv_back_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/icon_circle_green"
                    android:contentDescription="@string/back"
                    android:padding="8dp"
                    android:stateListAnimator="@animator/btn_bounce"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Past Incidents"
                    android:textColor="@color/pastel_green_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_filter"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/icon_circle_orange"
                    android:contentDescription="Filter"
                    android:padding="8dp"
                    android:stateListAnimator="@animator/btn_bounce"
                    android:src="@drawable/ic_search" />
            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Filters Section Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/pastel_card_elevated"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filter_7days"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_filter_active"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="7 Days"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@animator/btn_bounce" />

                <TextView
                    android:id="@+id/filter_30days"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_filter_inactive"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="30 Days"
                    android:textColor="@color/pastel_text_secondary"
                    android:textSize="12sp"
                    android:stateListAnimator="@animator/btn_bounce" />

                <TextView
                    android:id="@+id/filter_all"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_filter_inactive"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="All Time"
                    android:textColor="@color/pastel_text_secondary"
                    android:textSize="12sp"
                    android:stateListAnimator="@animator/btn_bounce" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/search_field_bg"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Search"
                    android:src="@drawable/ic_search" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Search by location..."
                    android:inputType="text"
                    android:textColor="@color/pastel_text_primary"
                    android:textColorHint="@color/pastel_text_muted"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/iv_clear_search"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Clear"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:visibility="gone"
                    app:tint="@color/pastel_text_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- Incidents List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_incidents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:alpha="0.9"
                android:contentDescription="No Data"
                android:src="@drawable/ic_shield_safe" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No Incidents Found"
                android:textColor="@color/pastel_green_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="No fire incidents have been reported yet."
                android:textColor="@color/pastel_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/btn_go_to_detect"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_detect_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:stateListAnimator="@animator/btn_bounce">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Detect"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report Fire"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btn_clear_all"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/btn_danger_soft"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:stateListAnimator="@animator/btn_bounce">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Clear All"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/pastel_danger" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear All"
                    android:textColor="@color/pastel_danger"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_new_detection"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:contentDescription="New Detection"
                android:src="@drawable/ic_camera"
                app:backgroundTint="@color/pastel_green"
                app:elevation="8dp"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
