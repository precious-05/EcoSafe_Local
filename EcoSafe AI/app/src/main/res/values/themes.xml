<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Eco_front" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/pastel_green</item>
        <item name="colorPrimaryContainer">@color/pastel_green_mist</item>
        <item name="colorSecondary">@color/pastel_orange</item>
        <item name="android:statusBarColor">@color/pastel_bg_mid</item>
        <item name="android:navigationBarColor">@color/pastel_card</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
    </style>

    <style name="Theme.Eco_front" parent="Base.Theme.Eco_front" />

    <!-- ✅ SPLASH THEME ADD KARO YAHAN -->
    <style name="SplashTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowFullscreen" type="boolean">true</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTranslucentStatus" type="boolean">true</item>
        <item name="android:windowTranslucentNavigation" type="boolean">true</item>
    </style>
</resources>